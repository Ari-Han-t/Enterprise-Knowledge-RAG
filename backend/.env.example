APP_ENV=development
JWT_SECRET=change-this-in-production
JWT_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads
REDIS_URL=redis://redis:6379/0

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

DENSE_VECTOR_SIZE=768

MAX_FILE_SIZE_BYTES=10485760
MAX_UPLOADS_PER_DAY=5
MAX_FILES_PER_UPLOAD=1
MAX_QUERIES_PER_MINUTE=4
MAX_QUERIES_PER_DAY=25
DEMO_GLOBAL_QUERIES_PER_MINUTE=8
DEMO_GLOBAL_QUERIES_PER_DAY=250
MAX_INPUT_TOKENS=1200
MAX_GENERATION_TOKENS=500

GROQ_REQUESTS_PER_MINUTE=20
GROQ_REQUESTS_PER_DAY=500
GROQ_TOKENS_PER_MINUTE=4000
GROQ_TOKENS_PER_DAY=100000
GROQ_MAX_CONCURRENT_REQUESTS=2
GROQ_ANSWER_SCORING_ENABLED=false

TOP_K_DENSE=8
TOP_K_KEYWORD=8
TOP_K_FINAL=6
QUERY_CACHE_TTL_SECONDS=1800

FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
